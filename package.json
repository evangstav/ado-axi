{
  "name": "ado-axi",
  "version": "0.1.0",
  "description": "AXI-compliant Azure DevOps CLI wrapper — token-efficient TOON output over `az repos` and `az boards` (pull requests, reviewers, and work items), with PAT+org auto-resolution. The ADO equivalent of gh-axi.",
  "type": "module",
  "keywords": [
    "azure-devops",
    "ado",
    "cli",
    "axi",
    "pull-request",
    "work-items",
    "toon",
    "agent",
    "az"
  ],
  "homepage": "https://github.com/evangstav/ado-axi#readme",
  "bugs": {
    "url": "https://github.com/evangstav/ado-axi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evangstav/ado-axi.git"
  },
  "bin": {
    "ado-axi": "./dist/bin/ado-axi.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx bin/ado-axi.ts",
    "prepack": "npm run build",
    "test": "npm run build && node --test test/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "axi-sdk-js": "^0.1.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
